# In all environments, the following files are loaded if they exist,
# the latter taking precedence over the former:
#
#  * .env                contains default values for the environment variables needed by the app
#  * .env.local          uncommitted file with local overrides
#  * .env.$APP_ENV       committed environment-specific defaults
#  * .env.$APP_ENV.local uncommitted environment-specific overrides
#
# Real environment variables win over .env files.
#
# DO NOT DEFINE PRODUCTION SECRETS IN THIS FILE NOR IN ANY OTHER COMMITTED FILES.
# https://symfony.com/doc/current/configuration/secrets.html
#
# Run "composer dump-env prod" to compile .env files for production use (requires symfony/flex >=1.2).
# https://symfony.com/doc/current/best_practices.html#use-environment-variables-for-infrastructure-configuration

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=
###< symfony/framework-bundle ###

###> symfony/routing ###
# Configure how to generate URLs in non-HTTP contexts, such as CLI commands.
# See https://symfony.com/doc/current/routing.html#generating-urls-in-commands
DEFAULT_URI=http://localhost
###< symfony/routing ###

###> doctrine/doctrine-bundle ###
# Format described at https://www.doctrine-project.org/projects/doctrine-dbal/en/latest/reference/configuration.html#connecting-using-a-url
# IMPORTANT: You MUST configure your server version, either here or in config/packages/doctrine.yaml
#
# DATABASE_URL="sqlite:///%kernel.project_dir%/var/data_%kernel.environment%.db"
# DATABASE_URL="mysql://app:!ChangeMe!@127.0.0.1:3306/app?serverVersion=8.0.32&charset=utf8mb4"
# DATABASE_URL="mysql://app:!ChangeMe!@127.0.0.1:3306/app?serverVersion=10.11.2-MariaDB&charset=utf8mb4"
# Real credentials live in .env.local (gitignored). This is a placeholder only.
DATABASE_URL="mysql://db_user:db_password@127.0.0.1:3306/mitr_sus?charset=utf8"
###< doctrine/doctrine-bundle ###

###> mmsch dictionary db (one-off sus:importcsv XLSX importer lookups) ###
# Secondary read-only connection to the MM database (old code hard-coded a local PDO DSN).
# Example: MMSCH_DB_DSN="mysql:host=localhost;dbname=mmsch;charset=utf8"
MMSCH_DB_DSN=
MMSCH_DB_USERNAME=
MMSCH_DB_PASSWORD=
###< mmsch dictionary db ###

###> mmsch api (App\Service\MMService — MMSyncableListener, sus:syncunits, unit autocomplete) ###
# Base URL of the MM API. The old app hard-coded https://mm.sch.gr/api/ (PRODUCTION —
# writes there create/update real units). Placeholder credentials only: real values
# (old app app/config/parameters.yml keys mmsch_username/mmsch_password) belong in
# .env.local / server env, never committed.
MMSCH_API_BASE_URL=https://mm.sch.gr/api/
MMSCH_API_USERNAME=mmsch_user
MMSCH_API_PASSWORD=mmsch_password
# Push Units/Workers to the MM API on every Doctrine flush (MMSyncableListener).
# Replaces the old `kernel.environment == 'prod'` gate — set true ONLY in production.
MMSCH_SYNC_ENABLED=false
###< mmsch api ###

###> app/cas-sso (security area) ###
# CAS SSO against sch.gr (SAML 1.1 ticket validation via /samlValidate).
# NOTE: the old app used sso-01.sch.gr everywhere; WORKPLAN says sso.sch.gr — confirm for prod.
CAS_HOST=sso.sch.gr
CAS_PORT=443
CAS_URI=
# Base URL of THIS app as registered with CAS (phpCAS 1.6 $service_base_url).
# No default: MUST be set per-environment (.env.local on dev = https://mmsch.uniwa.gr, prod = https://mm.sch.gr).
CAS_SERVICE_BASE_URL=
# 0 = verify the CAS server's TLS cert (secure default). Set to 1 ONLY in .env.local on a box
# that can't yet validate the chain. Never ship 1 as the committed default.
CAS_INSECURE_SKIP_VERIFY=0
###< app/cas-sso ###

###> app/sync-ldap (security area) ###
# LDAP lookup of "official school accounts" (old parameters.yml syncLdapOptions).
# Real bind password goes in .env.local (never commit it).
SYNC_LDAP_HOST=ldap.example.org
SYNC_LDAP_PORT=389
SYNC_LDAP_DN="uid=CHANGEME,ou=services,dc=example,dc=org"
SYNC_LDAP_PASSWORD=CHANGE_ME
###< app/sync-ldap ###
